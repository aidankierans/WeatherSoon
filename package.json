{
  "name": "weathersoon",
  "author": "Aidan Kierans",
  "version": "1.0.3",
  "license": "MIT",
  "repo": "aidankierans/WeatherSoon",
  "keywords": [
    "pebble-app"
  ],
  "private": false,
  "dependencies": {
    "@rebble/clay": "^1.0.8"
  },
  "pebble": {
    "displayName": "Weather Soon",
    "uuid": "53d53e85-9daf-41d7-94eb-33277bc7267f",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery"
    ],
    "projectType": "native",
    "watchapp": {
      "watchface": true
    },
    "capabilities": [
      "configurable",
      "location"
    ],
    "messageKeys": {
      "PrimaryColor": 4,
      "TempUnit": 13,
      "Canvas": 15,
      "HOURLY_TEMP_0": 16,
      "HOURLY_TEMP_1": 17,
      "HOURLY_TEMP_2": 18,
      "HOURLY_PRECIP_0": 19,
      "HOURLY_PRECIP_1": 20,
      "HOURLY_PRECIP_2": 21,
      "HOURLY_UV_0": 22,
      "HOURLY_UV_1": 23,
      "HOURLY_UV_2": 24
    },
    "resources": {
      "media": [
        {
          "type": "png",
          "name": "PEBBLE_LOGO",
          "file": "images/pebble_logo.png"
        },
        {
          "type": "png",
          "name": "MENU_ICON",
          "file": "images/menu_icon.png",
          "menuIcon": true
        },
        {
          "type": "png",
          "name": "SNEAKER_ICON",
          "file": "images/sneaker.png"
        },
        {
          "type": "font",
          "name": "FONT_INTER_SEMIBOLD_16",
          "file": "fonts/Inter-SemiBold.ttf",
          "characterRegex": "[ -~°]",
          "compatibility": "2.7"
        },
        {
          "type": "font",
          "name": "FONT_INTER_SEMIBOLD_20",
          "file": "fonts/Inter-SemiBold.ttf",
          "characterRegex": "[ -~]",
          "compatibility": "2.7"
        },
        {
          "type": "font",
          "name": "FONT_INTER_SEMIBOLD_24",
          "file": "fonts/Inter-SemiBold.ttf",
          "characterRegex": "[ -~°]",
          "compatibility": "2.7"
        },
        {
          "type": "font",
          "name": "FONT_INTER_SEMIBOLD_52",
          "file": "fonts/Inter-SemiBold.ttf",
          "characterRegex": "[0-9: ]",
          "compatibility": "2.7"
        }
      ]
    }
  }
}
